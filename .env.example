# Credit Card Hacking Toolkit — environment variables
# Copy to .env and fill in. Or use scripts/setup-keys.sh for masked input
# that writes to your shell rc directly.

# --- Optional: loyalty balance auto-pull ---------------------------------
# Reuses the travel-hacking-toolkit AwardWallet integration. If both are set,
# the agent will auto-pull your balances and card list at session start.
AWARDWALLET_API_KEY=
AWARDWALLET_USER_ID=

# --- Optional: Reddit API (for r/churning DPs) --------------------------
# Used by data-refresh scripts to scrape the daily/weekly DP threads. Free
# tier (60 requests/min) is plenty for weekly refresh.
# Sign up: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="credit-card-hacker/0.1 by yourname"

# --- Optional: where the user profile lives -----------------------------
# Defaults to ./profile.json (this repo, gitignored). Override if you want
# it under 1Password, a synced folder, or somewhere outside the repo.
CARD_HACKER_PROFILE_PATH=
