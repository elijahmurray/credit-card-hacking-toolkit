#!/usr/bin/env bash
# Pre-commit: keep agents/credit-card-hacker.md in sync with CLAUDE.md.
#
# If CLAUDE.md is staged, regenerate the agent file and stage the result.
# Install with: bash scripts/install-hooks.sh

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if git diff --cached --name-only | grep -q '^CLAUDE\.md$'; then
  bash "$REPO_ROOT/scripts/sync-agent.sh"
  git add "$REPO_ROOT/agents/credit-card-hacker.md"
  echo "Pre-commit: synced agents/credit-card-hacker.md from CLAUDE.md"
fi
