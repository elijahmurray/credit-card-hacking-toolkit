# Copy to .env.local and fill in.

# --- Supabase (auth + DB) -----------------------------------------------
# Get these from your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, NEVER expose

# --- Anthropic (Claude API) ---------------------------------------------
# Get from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe -------------------------------------------------------------
# Test keys for local; live keys for prod (set in Vercel env vars)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # from `stripe listen`
STRIPE_PRICE_ID_PRO=price_...                     # Stripe price for Pro tier
STRIPE_PRICE_ID_POWER=price_...                   # Stripe price for Power tier

# --- App config ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000          # used for Stripe redirects
